# API Configuration
API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Admin Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3001

# Database (if needed for admin-specific data)
DATABASE_URL=your-database-url-here

# Admin Settings
ADMIN_EMAIL=admin@goalinstitute.com
ADMIN_PASSWORD=your-admin-password

# DigitalOcean Spaces Configuration
DO_SPACES_ACCESS_KEY=your-access-key
DO_SPACES_SECRET_KEY=your-secret-key
DO_SPACES_ENDPOINT=your-endpoint (e.g., https://nyc3.digitaloceanspaces.com)
DO_SPACES_REGION=your-region (e.g., nyc3)
DO_SPACES_BUCKET=your-bucket-name
NEXT_PUBLIC_DO_SPACES_ENDPOINT=your-public-endpoint (e.g., https://your-bucket.nyc3.cdn.digitaloceanspaces.com)